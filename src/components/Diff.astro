---
const { title = "React → Astro" } = Astro.props;
---
<aside class="diff">
  <p class="diff__label">🔀 {title}</p>
  <slot />
</aside>
<style>
  .diff { border-left: 4px solid #FF3E00; background: var(--sl-color-accent-low); color: var(--sl-color-accent-high); padding: 0.75rem 1rem; border-radius: 0 6px 6px 0; margin: 1rem 0; }
  .diff__label { font-weight: 700; margin: 0 0 .25rem; color: var(--sl-color-accent-high); }
</style>
